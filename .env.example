# Copy this file to .env and fill in real values. Never commit .env.

# --- Gemini (Google AI Studio free tier) ---
GEMINI_API_KEY=your-google-ai-studio-key-here
GEMINI_MODEL_NAME=gemini-2.5-flash

# --- Which backend serves a capability when a caller doesn't pin one ---
GENERATION_PRIMARY_BACKEND=gemini

# --- Gateway auth: comma-separated caller_name:key pairs ---
# Example below defines one caller "local_dev" with key "dev-secret-123"
GATEWAY_API_KEYS=local_dev:dev-secret-123

# --- Local SQLite log store ---
GATEWAY_DB_PATH=gateway.db
